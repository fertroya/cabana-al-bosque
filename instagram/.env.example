# Meta / Instagram Graph API
# Guía completa: SETUP-AUTOMATION.md

# instagram = graph.instagram.com (Instagram Login) | facebook = graph.facebook.com (Página de FB)
INSTAGRAM_API_BASE=instagram

# App ID de la captura (CabanaAlBosqueSync-IG)
META_APP_ID=1354064783314751
META_APP_SECRET=

# Token de larga duración con permisos:
# instagram_basic, instagram_content_publish, pages_show_list, pages_read_engagement
META_ACCESS_TOKEN=

# ID numérico de la cuenta profesional de Instagram (no el @usuario)
INSTAGRAM_USER_ID=

# URL pública donde viven las imágenes exportadas (GitHub Pages)
PUBLIC_BASE_URL=https://fertroya.github.io/cabana-al-bosque/instagram/export

# Minutos entre cada post al publicar el lote (0 = seguidos con pausa de 5s)
POST_INTERVAL_MINUTES=30
